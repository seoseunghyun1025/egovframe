<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="egovframework.member.service.impl.MemberMapper">
	
	<resultMap id="MemberMap" type="egovframework.member.dto.Member">
    	<result property="memberId" column="MEMBER_ID"/>
    	<result property="email" column="EMAIL"/>
    	<result property="password" column="TX_TYPE"/>
    	<result property="name" column="BUY_PRICE"/>
    	<result property="registerDateTime" column="REGISTER_DATE_TIME"/>
	</resultMap>

    <insert id="regist" parameterType="egovframework.member.dto.Register">
    	INSERT INTO MEMBER(
    		EMAIL,
            PASSWORD,
            NAME,
            REGISTER_DATE_TIME
    	) VALUES(
    		#{email},
    		#{password},
    		#{name},
    		SYSDATE
    	)
    </insert>
    
    <select id="select" parameterType="egovframework.member.dto.Member" resultMap="MemberMap">
    	SELECT EMAIL
    	FROM MEMBER
    	WHERE EMAIL = #{email}
    </select>

</mapper>